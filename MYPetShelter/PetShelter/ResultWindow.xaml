<Window x:Class="PetShelter.Wpf.ResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetShelter"
        mc:Ignorable="d"
        Title="📊 Результаты поиска питомцев" 
        Height="550" Width="900"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <!-- Верхняя панель с информацией -->
        <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="txtInfo" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Нижняя панель с кнопками -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="➕ Добавить питомца" 
                    Width="140" Background="Violet" Foreground="Ivory"
                    Click="BtnAdd_Click"/>
            <Button x:Name="btnRemove" Content="❌ Удалить выбранного" 
                    Width="140" Background="DarkMagenta" Foreground="Ivory"
                    Click="BtnRemove_Click"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" 
                    Width="100" Background="IndianRed" Foreground="White"
                    Click="BtnRefresh_Click"/>
            <Button x:Name="btnClose" Content="✖ Закрыть" 
                    Width="100" Background="Firebrick" Foreground="White"
                    Click="BtnClose_Click"/>
        </StackPanel>

        <!-- Таблица с питомцами -->
        <DataGrid x:Name="dgPets" 
                  AutoGenerateColumns="True" 
                  SelectionMode="Single" 
                  SelectionUnit="FullRow"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <!-- Настройка колонки с клаустрофобией для лучшего отображения -->
                <DataGridCheckBoxColumn Header="Клаустрофобия" 
                                       Binding="{Binding HasClaustrophobia}"
                                       IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
