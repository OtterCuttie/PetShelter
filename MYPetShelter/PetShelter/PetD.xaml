<Window x:Class="PetShelter.AddPetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetShelter"
        mc:Ignorable="d"
        Title="➕ Добавление нового питомца" 
        Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Информация о питомце" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Тип животного:"/>
        <ComboBox x:Name="cmbPetType" Grid.Row="1" Grid.Column="1" 
                  SelectionChanged="CboxPetType_SelectionChanged">
            <ComboBoxItem Content="🐱 Кошка" IsSelected="True"/>
            <ComboBoxItem Content="🐕 Собака"/>
            <ComboBoxItem Content="🐇 Кролик"/>
            <ComboBoxItem Content="🦊 Лиса"/>
            <ComboBoxItem Content="🦝 Енот"/>
            <ComboBoxItem Content="🦜 Попугай"/>
        </ComboBox>

        <Label Grid.Row="2" Grid.Column="0" Content="Кличка:"/>
        <TextBox x:Name="txtName" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Возраст (лет):"/>
        <TextBox x:Name="txtAge" Grid.Row="3" Grid.Column="1" Margin="0,5" Text="1"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Вес (кг):"/>
        <TextBox x:Name="txtWeight" Grid.Row="4" Grid.Column="1" Margin="0,5" Text="5.0"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Особые приметы:"/>
        <TextBox x:Name="txtSpecialMarks" Grid.Row="5" Grid.Column="1" Margin="0,5" 
                 Text="Нет"/>

        <CheckBox x:Name="chkClaustrophobia" Grid.Row="6" Grid.Column="1" 
                  Content="Имеет клаустрофобию" Margin="0,10" />

        <!-- Специфические поля для разных типов -->
        <Border Grid.Row="7" Grid.ColumnSpan="2" BorderBrush="#CCCCCC" 
                BorderThickness="1" CornerRadius="5" Margin="0,10,0,0" Padding="10">
            <StackPanel x:Name="spSpecificFields">
                <TextBlock Text="Дополнительные параметры" FontWeight="Bold" Margin="0,0,0,5"/>
                <!-- Здесь будут динамически добавляться поля -->
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnOk" Content="✅ Добавить" Width="100" 
                    Click="BtnOk_Click" Background="OliveDrab" Foreground="White"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Width="100" 
                    Click="BtnCancel_Click" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
