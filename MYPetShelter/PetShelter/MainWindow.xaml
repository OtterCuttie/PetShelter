<Window x:Class="PetShelter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetShelter"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="600" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="10"/> <!--внешние отступы-->
            <Setter Property="Padding" Value="10"/> <!--Внутренние отступы-->
            <Setter Property="FontWeight"Value="Bold"/> <!--жирный шрифт-->
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/> <!--размер шрифта-->
            <Setter Property="Cursor" Value="Hand"/> <!--курсор меняется на "руку"-->
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>      <!--+7строк-->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="🐾 Поиск питомцев в приютах 🐾"
            FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0, 0, 0, 20"/>
        <!--фильтры-->
        <GroupBox Grid.Row="1" Header="Параметры поиска">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Выберите приют:"/>
                <ComboBox x:Name="cboxShelters" Grid.Row="0" Grid.Column="1"
                          DisplayMemberPath="Name"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Вид животного:"/>
                <ComboBox x:Name="cm" Grid.Row="0" Grid.Column="1"
          DisplayMemberPath="Name"/>
                <!--Выбор вида животного-->
                <Label Grid.Row="1" Grid.Column="0" Content="Вид животного:"/>
                <ComboBox x:Name="cboxAnimalTypes" Grid.Row="1" Grid.Column="1">
                    <ComboBoxItem Content="Все животные" IsSelected="True"/>
                    <Separator/>
                    <ComboBoxItem Content="🐱 Кошка"/>
                    <ComboBoxItem Content="🐕 Собака"/>
                    <ComboBoxItem Content="🐇 Кролик"/>
                    <ComboBoxItem Content="🦊 Лиса"/>
                    <ComboBoxItem Content="🦝 Енот"/>
                    <ComboBoxItem Content="🦜 Попугай"/>
                </ComboBox>
                <CheckBox x:Name="ckOnlyOpenArea" Grid.Row="2" Grid.Column="1"
                          Content="Показывать только приюты с открытой территорией"
                          Margin="5,10,5,5"/>
            </Grid>
        </GroupBox>
         <!-- формат отчётов -->
        <GroupBox Grid.Row="2" Header="Настройки отчётов">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Формат отчёта:"/>
                <ComboBox x:Name="cboxrprtFormat" Grid.Column="1" SelectedIndex="0">
                    <ComboBoxItem Content="JSON"/>
                    <ComboBoxItem Content="XML"/>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="(отчёты сохраняются автоматически)"
                           FontSize="11" Foreground="CadetBlue" VerticalAlignment="Center" Margin="10, 0, 0, 0"/>
            </Grid>
        </GroupBox>

        <!-- Кнопка поиска -->
        <Button x:Name="btShow" Grid.Row="3" Content="НАЙТИ ПИТОМЦЕВ"
                Background="MistyRose" Foreground="DarkRed" FontWeight="Bold"
                Width="200" Height="40" HorizontalAlignment="Center"
                Click="BtnShow_Click" Cursor="Hand"/>

        <StatusBar Grid.Row="6" VerticalAlignment="Bottom">
            <StatusBarItem x:Name="statusText" Content="Готов к работе"/>
        </StatusBar>
    </Grid>
</Window>
